<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ApsGenerator.UI.ViewModels"
        xmlns:models="using:ApsGenerator.UI.Models"
        xmlns:core="using:ApsGenerator.Core.Models"
        xmlns:controls="using:ApsGenerator.UI.Controls"
        x:Class="ApsGenerator.UI.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="APS Tetris Generator"
        Icon="avares://ApsGenerator.UI/Assets/Icons/icon.ico"
        Width="1024" Height="768"
        MinWidth="800" MinHeight="600">

    <Window.Styles>
        <Style Selector="HeaderedContentControl.section">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="#2A2A2E"
                            BorderBrush="#3F3F46"
                            BorderThickness="1"
                            CornerRadius="6"
                            ClipToBounds="True">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    Background="#0f0f0f"
                                    Padding="12,6">
                                <ContentPresenter Content="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
                                                  FontWeight="SemiBold" FontSize="13" />
                            </Border>
                            <Border Padding="12,8">
                                <ContentPresenter Content="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Border>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
    </Window.Styles>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+G" Command="{Binding GenerateCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding CancelCommand}" />
        <KeyBinding Gesture="Left" Command="{Binding PrevSolutionCommand}" />
        <KeyBinding Gesture="Right" Command="{Binding NextSolutionCommand}" />
        <KeyBinding Gesture="Ctrl+O" Command="{Binding ToggleCoolerOverlayCommand}" />
    </Window.KeyBindings>

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
        </LayoutTransformControl.LayoutTransform>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Settings" Click="OnSettingsClick" />
        </Menu>

        <Grid ColumnDefinitions="320,*">

        <!-- Left Panel -->
        <Border Grid.Column="0" Margin="4" VerticalAlignment="Top">
            <ScrollViewer MaxHeight="{Binding $parent[Grid].Bounds.Height}">
                <StackPanel Margin="4" Spacing="8">

                <!-- TEMPLATE section -->
                <HeaderedContentControl Classes="section" Header="Template">
                    <StackPanel Spacing="8">

                        <TextBlock Text="Shape" FontSize="12" Foreground="#AAAAAA" />
                        <ComboBox ItemsSource="{x:Static models:TemplateShapeValues.All}"
                                  SelectedItem="{Binding TemplateShape}"
                                  HorizontalAlignment="Stretch"
                                  ToolTip.Tip="Base template shape for the grid">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Grid ColumnDefinitions="*,Auto,*">
                            <NumericUpDown Grid.Column="0" Value="{Binding TemplateWidth}"
                                           Minimum="3" Maximum="50" Increment="1" FormatString="0"
                                           ToolTip.Tip="Grid width" />
                            <ToggleButton Grid.Column="1" IsChecked="{Binding IsHeightLocked, Mode=TwoWay}"
                                          Content="⇔" FontSize="14" Padding="6,2"
                                          ToolTip.Tip="Lock dimensions together" />
                            <NumericUpDown Grid.Column="2" Value="{Binding TemplateHeight}"
                                           IsEnabled="{Binding IsHeightEditable}"
                                           Minimum="3" Maximum="50" Increment="1" FormatString="0"
                                           ToolTip.Tip="Grid height" />
                        </Grid>

                        <TextBlock Text="Paint Mode" FontSize="12" Foreground="#AAAAAA" />
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <RadioButton Content="Block" GroupName="PaintMode"
                                         IsChecked="{Binding IsPaintModeBlock, Mode=OneWay}"
                                         Command="{Binding SetPaintModeCommand}"
                                         CommandParameter="{x:Static models:PaintMode.Block}"
                                         ToolTip.Tip="Click cells to set them as blocked" />
                            <RadioButton Content="Clear" GroupName="PaintMode"
                                         IsChecked="{Binding IsPaintModeClear, Mode=OneWay}"
                                         Command="{Binding SetPaintModeCommand}"
                                         CommandParameter="{x:Static models:PaintMode.Clear}"
                                         ToolTip.Tip="Click cells to set them as available" />
                            <RadioButton Content="Toggle" GroupName="PaintMode"
                                         IsChecked="{Binding IsPaintModeToggle, Mode=OneWay}"
                                         Command="{Binding SetPaintModeCommand}"
                                         CommandParameter="{x:Static models:PaintMode.Toggle}"
                                         ToolTip.Tip="Click cells to toggle between blocked and available" />
                        </StackPanel>

                        <Button Content="Reset to Template"
                                Command="{Binding ResetToTemplateCommand}"
                                HorizontalAlignment="Stretch"
                                ToolTip.Tip="Reset grid to the selected template shape" />
                    </StackPanel>
                </HeaderedContentControl>

                <!-- SOLVER section -->
                <HeaderedContentControl Classes="section" Header="Solver">
                    <StackPanel Spacing="8">

                        <TextBlock Text="Tetris Type" FontSize="12" Foreground="#AAAAAA" />
                        <ComboBox ItemsSource="{x:Static vm:EnumValues.TetrisTypes}"
                                  SelectedItem="{Binding SelectedTetrisType}"
                                  HorizontalAlignment="Stretch"
                                  ToolTip.Tip="Tetromino piece type used by the solver">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Symmetry" FontSize="12" Foreground="#AAAAAA" />
                        <Grid ColumnDefinitions="*,Auto">
                            <ComboBox Grid.Column="0" ItemsSource="{x:Static vm:EnumValues.SymmetryTypes}"
                                      SelectedItem="{Binding SelectedSymmetryType}"
                                      HorizontalAlignment="Stretch"
                                      ToolTip.Tip="Symmetry constraint for placement">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <CheckBox Grid.Column="1" Content="Hard"
                                      IsChecked="{Binding IsHardSymmetry}"
                                      IsEnabled="{Binding IsSymmetryEnabled}"
                                      VerticalAlignment="Center" Margin="8,0,0,0"
                                      ToolTip.Tip="Hard: every placement must have a valid symmetric counterpart. Soft: symmetric pairs are preferred but asymmetric placements are allowed where the counterpart would be invalid." />
                        </Grid>

                        <TextBlock Text="⚠ Rotation90 requires a square grid"
                                   Foreground="#FF9800" FontSize="11" TextWrapping="Wrap"
                                   IsVisible="{Binding IsRotation90NonSquareWarning}" />

                        <TextBlock Text="Density" FontSize="12" Foreground="#AAAAAA" />
                        <TextBlock Text="{Binding DensityDisplayText}" Margin="0,0,0,-4" />
                        <Slider Minimum="{Binding SliderMinimum}"
                                Maximum="{Binding SliderMaximum}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding TargetPlacementCount}"
                                ToolTip.Tip="Target number of pieces to place. Maximum = maximize." />

                        <Separator Margin="0,4" />

                        <TextBlock Text="Solutions" FontSize="12" Foreground="#AAAAAA" />
                        <NumericUpDown Value="{Binding NumSolutions}"
                                       Minimum="1" Maximum="50" Increment="1"
                                       FormatString="0" HorizontalAlignment="Stretch" Margin="0,0,0,4"
                                       ToolTip.Tip="Number of solutions to generate" />

                        <Button Content="Generate (Ctrl+G)"
                                Command="{Binding GenerateCommand}"
                                HorizontalAlignment="Stretch"
                                Classes="accent" />

                        <Button Content="Cancel (Esc)"
                                Command="{Binding CancelCommand}"
                                IsVisible="{Binding IsGenerating}"
                                HorizontalAlignment="Stretch" />

                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding IsGenerating}"
                                     Height="4" />
                    </StackPanel>
                </HeaderedContentControl>

                <!-- STATUS section (only visible after solve) -->
                <HeaderedContentControl Classes="section" Header="Status"
                                        IsVisible="{Binding HasSolverRun}">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="4"
                                    IsVisible="{Binding PlacedText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="Placed:" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding PlacedText}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Status:" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StatusLabel}"
                                       Foreground="{Binding StatusForeground}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4"
                                    IsVisible="{Binding ElapsedTimeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="Time:" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ElapsedTimeText}" />
                        </StackPanel>
                        <TextBlock Text="{Binding StatusDetailText}"
                                   TextWrapping="Wrap"
                                   Foreground="#F44336"
                                   IsVisible="{Binding StatusDetailText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                </HeaderedContentControl>

                <!-- EXPORT section -->
                <HeaderedContentControl Classes="section" Header="Export">
                    <StackPanel Spacing="8">

                        <Button Content="Export Blueprint"
                                Command="{Binding ExportCommand}"
                                Classes="accent"
                                HorizontalAlignment="Stretch"
                                ToolTip.Tip="Export the current solution as a game blueprint" />
                    </StackPanel>
                </HeaderedContentControl>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="8" Margin="4"
                        IsVisible="{Binding HasMultipleSolutions}">
                <Button Content="◀" Command="{Binding PrevSolutionCommand}"
                        MinWidth="32" HorizontalContentAlignment="Center" />
                <TextBlock Text="{Binding SolutionCounterText}"
                           VerticalAlignment="Center" FontWeight="SemiBold" />
                <Button Content="▶" Command="{Binding NextSolutionCommand}"
                        MinWidth="32" HorizontalContentAlignment="Center" />
            </StackPanel>

            <controls:GridCanvas x:Name="GridCanvas"
                                 Grid.Row="1"
                                 Margin="4"
                                 ClipToBounds="True"
                                 Grid="{Binding Grid}"
                                 PaintMode="{Binding PaintMode}"
                                 SolverResult="{Binding SolverResult}"
                                 TetrisType="{Binding SelectedTetrisType.Value}"
                                 SymmetryType="{Binding SelectedSymmetryType.Value}"
                                 />
        </Grid>

    </Grid>
    </DockPanel>
    </LayoutTransformControl>

</Window>
